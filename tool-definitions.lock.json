    {
      "name": "consumption_search_bfe_datasets",
      "description": "Search opendata.swiss CKAN for energy / electricity datasets. Filter by BFE organisation. Use to find raw datasets not covered by other tools.",
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "input_schema": {
        "properties": {
          "query": {
            "description": "Free-text search",
            "maxLength": 200,
            "minLength": 1,
            "title": "Query",
            "type": "string"
          },
          "bfe_only": {
            "default": true,
            "title": "Bfe Only",
            "type": "boolean"
          },
          "limit": {
            "default": 20,
            "maximum": 50,
            "minimum": 1,
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "default": 0,
            "minimum": 0,
            "title": "Offset",
            "type": "integer"
          },
          "response_format": {
            "default": "markdown",
            "enum": [
              "json",
              "markdown"
            ],
            "title": "Response Format",
            "type": "string"
          }
        },
        "required": [
          "query"
        ],
        "title": "consumption_search_bfe_datasetsArguments",
        "type": "object"
      }
    },
