            "type": "integer"
          },
          "response_format": {
            "default": "markdown",
            "enum": [
              "json",
              "markdown"
            ],
            "title": "Response Format",
            "type": "string"
          }
        },
        "title": "dashboard_get_consumption_forecastArguments",
        "type": "object"
      }
    },
    {
      "name": "dashboard_get_production_mix",
      "description": "Get the Swiss electricity production mix (Kernkraft, Wasserkraft, PV, Wind ...) by year, with absolute TWh and percentage shares. Source: Energiedashboard.ch (BFE).",
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "input_schema": {
        "properties": {
          "response_format": {
            "default": "markdown",
