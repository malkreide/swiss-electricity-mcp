    {
      "name": "tariff_compare_municipalities",
      "description": "Compare electricity tariffs across multiple municipalities (BFS-Nrs) for one category and year. One row per (municipality, operator). Useful for procurement, benchmarking, school-network analysis.",
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "input_schema": {
        "properties": {
          "bfs_numbers": {
            "items": {
              "type": "integer"
            },
            "maxItems": 20,
            "minItems": 1,
            "title": "Bfs Numbers",
            "type": "array"
          },
          "category": {
            "description": "Verbrauchskategorie (e.g. C3)",
            "maxLength": 4,
            "minLength": 1,
            "title": "Category",
            "type": "string"
          },
          "period": {
            "maximum": 2100,
            "minimum": 2009,
            "title": "Period",
            "type": "integer"
          },
          "response_format": {
            "default": "markdown",
            "enum": [
              "json",
              "markdown"
            ],
            "title": "Response Format",
            "type": "string"
          }
        },
        "required": [
          "bfs_numbers",
          "category",
          "period"
        ],
        "title": "tariff_compare_municipalitiesArguments",
        "type": "object"
      }
    },
    {
      "name": "tariff_get_by_municipality",
      "description": "Get ElCom tariff observations for a Swiss municipality (BFS-Nr). Returns total rate in Rp./kWh broken down by energy, grid usage, public charges (KEV, Abgaben). Filterable by category (e.g. C3 for schools) and year range. Example: bfs_nr=261 for Zuerich, category='C3', period_from=2019.",
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "input_schema": {
        "properties": {
          "bfs_nr": {
            "description": "BFS-Gemeindenummer (e.g. 261=Zuerich)",
            "minimum": 1,
            "title": "Bfs Nr",
            "type": "integer"
          },
          "category": {
            "anyOf": [
              {
                "maxLength": 4,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Verbrauchskategorie",
            "title": "Category"
          },
          "period_from": {
            "anyOf": [
              {
                "minimum": 2009,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Period From"
          },
          "period_to": {
            "anyOf": [
              {
                "maximum": 2100,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Period To"
          },
          "limit": {
            "default": 100,
            "maximum": 500,
            "minimum": 1,
            "title": "Limit",
            "type": "integer"
          },
          "response_format": {
            "default": "markdown",
            "enum": [
              "json",
              "markdown"
            ],
            "title": "Response Format",
            "type": "string"
          }
        },
        "required": [
          "bfs_nr"
        ],
        "title": "tariff_get_by_municipalityArguments",
        "type": "object"
      }
    },
