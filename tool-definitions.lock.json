          "response_format": {
            "default": "markdown",
            "enum": [
              "json",
              "markdown"
            ],
            "title": "Response Format",
            "type": "string"
          }
        },
        "title": "dashboard_get_consumer_price_indexArguments",
        "type": "object"
      }
    },
    {
      "name": "dashboard_get_consumption_forecast",
