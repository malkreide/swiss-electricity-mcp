              "json",
              "markdown"
            ],
            "title": "Response Format",
            "type": "string"
          }
        },
        "title": "dashboard_get_production_mixArguments",
        "type": "object"
      }
    },
    {
      "name": "dashboard_get_storage_lakes",
      "description": "Get storage-lake (Speichersee) fill level for Switzerland or a region: current fill in % and GWh, 5-year envelope, full time series. Critical indicator for winter supply security.",
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "input_schema": {
        "properties": {
          "region": {
            "default": "totalCH",
            "description": "Region selector.",
            "enum": [
              "totalCH",
              "Wallis",
              "Tessin",
              "Graubuenden",
              "ZentralOst"
            ],
            "title": "Region",
            "type": "string"
          },
          "limit_weeks": {
            "default": 52,
            "maximum": 300,
            "minimum": 1,
            "title": "Limit Weeks",
            "type": "integer"
          },
          "response_format": {
            "default": "markdown",
            "enum": [
              "json",
              "markdown"
            ],
            "title": "Response Format",
            "type": "string"
          }
        },
        "title": "dashboard_get_storage_lakesArguments",
        "type": "object"
      }
    },
